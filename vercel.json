{
  "version": 2,
  "builds": [
    {
      "src": "blitzkrieg.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/chat.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/chat",
      "dest": "/api/chat.py"
    },
    {
      "src": "/(.*)",
      "dest": "/blitzkrieg.html"
    }
  ]
}
